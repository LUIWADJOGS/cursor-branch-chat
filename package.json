{
  "name": "cursor-branch-chat",
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "version": "0.2.3",
  "publisher": "LUIWADJOGS",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/LUIWADJOGS/cursor-branch-chat.git"
  },
  "homepage": "https://github.com/LUIWADJOGS/cursor-branch-chat#readme",
  "bugs": {
    "url": "https://github.com/LUIWADJOGS/cursor-branch-chat/issues"
  },
  "keywords": [
    "cursor",
    "chat",
    "git",
    "branch",
    "composer",
    "ai"
  ],
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "media/icon.png",
  "activationEvents": [
    "onView:branchChats.branchChatsView",
    "onCommand:cursorBranchChat.createBranchChat",
    "onCommand:cursorBranchChat.attachCurrentChatToBranch",
    "onCommand:cursorBranchChat.showChatsForCurrentBranch"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cursorBranchChat.createBranchChat",
        "title": "%commands.createBranchChat.title%"
      },
      {
        "command": "cursorBranchChat.showChatsForCurrentBranch",
        "title": "%commands.showChatsForCurrentBranch.title%"
      },
      {
        "command": "cursorBranchChat.attachCurrentChatToBranch",
        "title": "%commands.attachCurrentChatToBranch.title%"
      },
      {
        "command": "cursorBranchChat.changeChatBranch",
        "title": "%commands.changeChatBranch.title%"
      },
      {
        "command": "cursorBranchChat.openChat",
        "title": "%commands.openChat.title%"
      },
      {
        "command": "cursorBranchChat.copyPrompt",
        "title": "%commands.copyPrompt.title%"
      },
      {
        "command": "cursorBranchChat.archiveChat",
        "title": "%commands.archiveChat.title%"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "branchChats",
          "title": "%views.container.title%",
          "icon": "$(comment-discussion)"
        }
      ]
    },
    "views": {
      "branchChats": [
        {
          "id": "branchChats.branchChatsView",
          "name": "%views.branchChats.name%"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "cursorBranchChat.createBranchChat",
          "when": "view == branchChats.branchChatsView",
          "group": "navigation"
        },
        {
          "command": "cursorBranchChat.attachCurrentChatToBranch",
          "when": "view == branchChats.branchChatsView",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "cursorBranchChat.openChat",
          "when": "view == branchChats.branchChatsView && viewItem == entry"
        },
        {
          "command": "cursorBranchChat.copyPrompt",
          "when": "view == branchChats.branchChatsView && viewItem == entry"
        },
        {
          "command": "cursorBranchChat.changeChatBranch",
          "when": "view == branchChats.branchChatsView && viewItem == entry"
        },
        {
          "command": "cursorBranchChat.archiveChat",
          "when": "view == branchChats.branchChatsView && viewItem == entry"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.74.0",
    "typescript": "^5.3.0"
  }
}
